# Server Configuration
PORT=3000
NODE_ENV=development
HOST=localhost

# Twilio Configuration (for phone calling feature)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
NGROK_URL=http://localhost:3000

# Database
DB_PATH=./zakka-meet.db
# If deploying to Vercel (serverless), prefer an in-memory DB to avoid filesystem write errors
# Set DB_FILE to ":memory:" in Vercel project settings to use an in-memory SQLite DB
DB_FILE=:memory:

# Authentication
JWT_SECRET=your_jwt_secret_here_change_in_production

# Stripe (for monetization)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key

# Email (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Vercel Deployment
# On Vercel, set the environment variables in the Project Settings → Environment Variables
# Do NOT rely on a local .env file in Vercel production
VERCEL=false

# Feature Flags
ENABLE_RECORDINGS=true
ENABLE_MONETIZATION=true
ENABLE_CLINICAL_TESTS=true
ENABLE_PHONE_CALLING=true
